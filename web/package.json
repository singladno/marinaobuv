{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "22.19.0",
    "npm": ">=11.0.0"
  },
  "scripts": {
    "dev:simple": "next dev --turbopack",
    "dev": "next dev --turbopack & npm run lint:watch & npm run typecheck:watch",
    "lint:watch": "nodemon --watch src --ext ts,tsx,js,jsx --exec \"npm run lint\"",
    "docker:local": "docker-compose -f ../docker-compose.local.yml up -d && next dev --turbopack",
    "build": "next build",
    "build:local": "next build",
    "start": "next start",
    "start:local": "next start",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init_catalog",
    "prisma:seed": "tsx prisma/seed.ts",
    "prisma:reset": "prisma migrate reset --force",
    "fetch:messages": "tsx src/scripts/fetch-group-messages.ts",
    "fetch:recent": "tsx src/scripts/fetch-recent-messages.ts",
    "cron:hourly": "tsx src/scripts/hourly-cron.ts",
    "messages:clean": "tsx src/scripts/clean-messages.ts",
    "messages:clear": "tsx src/scripts/clear-messages.ts",
    "lint": "eslint .",
    "lint:eslint": "eslint . --ext .ts,.tsx,.js,.jsx --max-warnings 0",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "lint:check": "eslint . --ext .ts,.tsx,.js,.jsx --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "nodemon --watch src --ext ts,tsx --exec \"npm run typecheck\"",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "pre-commit": "lint-staged && npm run typecheck",
    "setup:local": "../run-local.sh",
    "docker:up": "docker-compose -f ../docker-compose.local.yml up -d",
    "docker:down": "docker-compose -f ../docker-compose.local.yml down",
    "docker:logs": "docker-compose -f ../docker-compose.local.yml logs -f"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.676.0",
    "@aws-sdk/lib-storage": "^3.888.0",
    "@aws-sdk/s3-request-presigner": "^3.888.0",
    "@heroicons/react": "^2.2.0",
    "@prisma/client": "^5.19.1",
    "@radix-ui/react-popover": "^1.1.15",
    "@tanstack/react-table": "8.21.3",
    "aws-sdk": "^2.1692.0",
    "bcryptjs": "^3.0.2",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.2",
    "https-proxy-agent": "^7.0.6",
    "jose": "^5.8.0",
    "lucide-react": "^0.544.0",
    "next": "15.5.3",
    "openai": "^5.20.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "tailwind-merge": "^3.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.1.0",
    "eslint": "^9",
    "nodemon": "^3.1.7",
    "eslint-config-next": "15.5.3",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0",
    "prettier-plugin-tailwindcss": "^0.5.0",
    "prisma": "^5.19.1",
    "tailwindcss": "^4",
    "tsx": "^4.19.2",
    "typescript": "^5"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
