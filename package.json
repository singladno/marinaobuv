{
  "name": "marinaobuv",
  "version": "1.0.0",
  "description": "Marina Obuv - Web Application",
  "private": true,
  "scripts": {
    "dev": "cd web && npm run dev",
    "build": "cd web && npm run build",
    "start": "cd web && npm run start",
    "install": "cd web && npm install",
    "lint": "cd web && npm run lint",
    "lint:fix": "cd web && npm run lint:fix",
    "typecheck": "cd web && npm run typecheck",
    "format": "cd web && npm run format",
    "format:check": "cd web && npm run format:check",
    "pre-commit": "cd web && npm run pre-commit",
    "prisma": "cd web && npx prisma studio",
    "fetch-messages": "cd web && npx tsx src/scripts/fetch-group-messages.ts",
    "draft:setup": "cd web && npx tsx src/scripts/setup-draft-products.ts",
    "draft:process": "cd web && npx tsx src/scripts/process-draft-products.ts",
    "draft:view": "cd web && npx tsx src/scripts/view-draft-products.ts"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  }
}
