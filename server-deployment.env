# Server Deployment Environment Variables
# Copy these to your server's .env file

# VPN Configuration for OpenAI Access
VPN_ENABLED=true
VPN_SERVER_IP=your-vps-ip-here
VPN_SERVER_PORT=51820
VPN_SERVER_PUBLIC_KEY=your-server-public-key-here
VPN_CLIENT_PRIVATE_KEY=your-client-private-key-here
VPN_CLIENT_PUBLIC_KEY=your-client-public-key-here

# Server Deployment
SERVER_SSH_HOST=your-server-ip
SERVER_SSH_USER=root
SERVER_SSH_KEY_PATH=~/.ssh/id_rsa
SERVER_DEPLOY_PATH=/var/www/marinaobuv
SERVER_NODE_VERSION=18

# Hetzner VPS (if using)
HETZNER_VPS_IP=your-hetzner-ip
HETZNER_VPS_USER=root
HETZNER_SSH_KEY_PATH=~/.ssh/hetzner_key

# WireGuard Configuration
WG_INTERFACE=wg0
WG_SERVER_IP=10.0.0.1
WG_CLIENT_IP=10.0.0.2
WG_DNS=8.8.8.8

# SSH Key Generation Commands
# ssh-keygen -t rsa -b 4096 -C "marinaobuv-server" -f ~/.ssh/marinaobuv_key
# ssh-keygen -t rsa -b 4096 -C "hetzner-vps" -f ~/.ssh/hetzner_key
